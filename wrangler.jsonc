{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "realestate-agent",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },

  "migrations": [
    {
      "new_sqlite_classes": ["RealEstateAgent"],
      "tag": "v1"
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "class_name": "RealEstateAgent",
        "name": "REAL_ESTATE_AGENT"
      }
    ]
  },

  "worker_loaders": [
    {
      "binding": "CODE_EXECUTOR"
    }
  ],

  "vars": {
    "LISTINGS_API_URL": "https://homefront-api.steep-recipe-f463.workers.dev"
  },

  "dev": {
    "port": 8788
  }
}
